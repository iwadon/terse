root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = tab
insert_final_newline = true
tab_width = 4
trim_trailing_whitespace = true

[*.s]
tab_width = 8

[*.json]
indent_size = 2
indent_style = space
tab_width = 8

[*.{yml,yaml}]
indent_size = 2
indent_style = space
tab_width = 8

[{CMakeLists.txt,*.cmake}]
indent_size = 2
indent_style = space
tab_width = 8

[{Jenkinsfile,Jenkinsfile-*}]
indent_size = 4
indent_style = tab
tab_width = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

